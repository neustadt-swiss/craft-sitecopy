{% import "_includes/forms" as forms %}

{% do view.registerAssetBundle("teamnovu\\sitecopy\\assetbundles\\sitecopy\\SitecopyAsset") %}

{% set siteCopyTargetOptions = craft.sitecopy.getSiteInputOptions(supportedSites, [siteId]) %}
{% set elementType = element is defined ? element.__class__|split('\\')|last : null %}

{% if siteCopyTargetOptions is not empty %}
    <div id="sitecopy" class="meta pane sitecopy" data-element-id="{{ elementId ?? '' }}" data-source-site-id="{{ currentSite ?? '' }}">
        {{ forms.lightswitchField({
            label: 'Copy to site'|t('site-copy-x'),
            id: 'siteCopy-toggle',
            name: 'sitecopy[enabled]',
            on: siteCopyEnabled ,
            toggle: '#sitecopy-options',
        }) }}

        <div class="{{ siteCopyEnabled ? '' : 'hidden' }} sitecopy-options" id="sitecopy-options">
            {{ forms.checkboxGroupField({
                label: "To which site should it be copied?"|t('site-copy-x'),
                id: 'siteCopy-targets',
                name: 'sitecopy[targets]',
                options: siteCopyTargetOptions,
                values: selectedSites ?? [],
            }) }}
            {{ forms.hidden({
                id: 'siteCopy-sourceSite',
                name: 'sitecopy[sourceSite]',
                value: currentSite ?? null,
            }) }}

            {% if siteCopyFields is defined and siteCopyFields is not empty %}
                <hr>
                {{ forms.hidden({
                    name: 'sitecopy[hasFieldSelection]',
                    value: '1',
                }) }}
                {{ forms.checkboxGroupField({
                    label: "Which fields to copy?"|t('site-copy-x'),
                    id: 'siteCopy-fields',
                    name: 'sitecopy[fieldsToSync]',
                    options: siteCopyFields,
                    values: siteCopyFieldHandles,
                }) }}
            {% endif %}
            <div id="sitecopy-unavailable-warning" class="hidden" style="margin-top: 8px; padding: 8px 10px; background: #fef3c7; border: 1px solid #f59e0b; border-radius: 4px; font-size: 13px; color: #92400e;"></div>
        </div>
    </div>

    <style>
        #sitecopy-options:not(.hidden) {
            padding-bottom: 24px;
        }
    </style>
{% endif %}
