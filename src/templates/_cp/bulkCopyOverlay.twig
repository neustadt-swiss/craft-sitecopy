{% import "_includes/forms" as forms %}

{% set siteCopyTargetOptions = craft.sitecopy.getSiteInputOptions(supportedSites, [siteId]) %}

<div class="body" style="overflow-y: scroll; max-height: 100%;">
    <form method="post" id="sitecopy-form">
        {{ csrfInput() }}

        <div class="main">
            {% if siteCopyTargetOptions is not empty %}
                <div class="pane sitecopy">
                    <div class="{{ siteCopyEnabled ? '' : 'hidden' }} sitecopy-options" id="sitecopy-options">
                        {{ forms.checkboxGroupField({
                            label: elementCount > 1 ? "To which site should the elements be copied?"|t('site-copy-x') : "To which site should it be copied?"|t('site-copy-x'),
                            id: 'siteCopy-targets',
                            name: 'sitecopy[targets]',
                            options: siteCopyTargetOptions,
                            values: selectedSites ?? [],
                        }) }}
                        {{ forms.hidden({
                            id: 'siteCopy-sourceSite',
                            name: 'sitecopy[sourceSite]',
                            value: siteId,
                        }) }}
                        {{ forms.hidden({
                            id: 'siteCopy-enabled',
                            name: 'sitecopy[enabled]',
                            value: siteCopyEnabled,
                        }) }}
                        <div id="sitecopy-unavailable-warning" class="hidden" style="margin-top: 8px; padding: 8px 10px; background: #fef3c7; border: 1px solid #f59e0b; border-radius: 4px; font-size: 13px; color: #92400e;"></div>
                    </div>
                </div>
            {% endif %}
        </div>
        <div class="buttons right">
            <input type="button" class="btn cancel" value="{{ 'Cancel'|t }}">
            <input type="submit" class="btn submit" name="submit" value="{{ 'Submit'|t }}">
        </div>
    </form>

    <script>
        (function() {
            const elementId = {{ ids[0] ?? 'null' }};
            const sourceSiteId = {{ siteId ?? 'null' }};

            async function updateBulkCopyWarning() {
                if (!elementId || !sourceSiteId) return;

                const warningEl = document.getElementById('sitecopy-unavailable-warning');
                if (!warningEl) return;

                const selectedTargets = Array.from(
                    document.querySelectorAll('input[name="sitecopy[targets]"]:checked')
                ).map(function(el) { return parseInt(el.value); });

                if (selectedTargets.length === 0) {
                    warningEl.classList.add('hidden');
                    return;
                }

                try {
                    const response = await fetch(Craft.getActionUrl('site-copy-x/api/check-site-availability'), {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': Craft.csrfTokenValue },
                        body: JSON.stringify({ elementId: elementId, sourceSiteId: sourceSiteId }),
                    });

                    const data = await response.json();
                    if (!data.success) return;

                    const availableIds = data.availableSites.map(function(s) { return s.id; });
                    const unavailableSelected = selectedTargets.filter(function(id) { return !availableIds.includes(id); });

                    if (unavailableSelected.length > 0) {
                        const names = data.unavailableSites
                            .filter(function(s) { return unavailableSelected.includes(s.id); })
                            .map(function(s) { return s.name; })
                            .join(', ');

                        warningEl.textContent = Craft.t('site-copy-x', 'Warning: the element does not exist on the following sites and will not be copied: {sites}', { sites: names });
                        warningEl.classList.remove('hidden');
                    } else {
                        warningEl.classList.add('hidden');
                    }
                } catch (e) {
                    console.error('sitecopy availability check failed', e);
                }
            }

            document.querySelectorAll('input[name="sitecopy[targets]"]').forEach(function(checkbox) {
                checkbox.addEventListener('change', updateBulkCopyWarning);
            });
        })();
    </script>
</div>
